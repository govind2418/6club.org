{
  "name": "bdgwin",
  "version": "1.0.0",
  "private": true,
  "description": "BDG Win website source.",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/generate-og.js",
    "dev": "node scripts/generate-og.js && vite build && concurrently -k -n VITE,SERVER -c yellow,cyan \"vite build --watch\" \"nodemon server/index.js\"",
    "build": "node scripts/generate-og.js && cross-env NODE_ENV=production vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "serve": "npm run build && npm start"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "lucide-static": "^0.399.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "cssnano": "^7.0.1",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.38",
    "sharp": "^0.33.4",
    "tailwindcss": "^3.4.3",
    "terser": "^5.31.0",
    "vite": "^5.2.11"
  }
}
