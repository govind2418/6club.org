      <div class="card-surface p-6">
        <%- icon('eye', 'w-6 h-6 text-gold') %>
        <p class="mt-3 text-sm font-semibold text-white">Fair Play Audits</p>
      </div>
      <div class="card-surface p-6">
        <%- icon('life-buoy', 'w-6 h-6 text-gold') %>
        <p class="mt-3 text-sm font-semibold text-white">Responsible Gaming Tools</p>
      </div>
    </div>
  </div>
</section>

<!-- Testimonials -->
