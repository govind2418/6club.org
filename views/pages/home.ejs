<!-- Hero -->
<section class="relative overflow-hidden pb-20 pt-32 lg:pt-40">
  <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(circle at 22% 20%, rgba(244,197,66,.16), transparent 55%), radial-gradient(circle at 82% 60%, rgba(139,94,23,.18), transparent 50%);"></div>

  <!-- Drifting particles (CSS only) -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <span class="particle h-1.5 w-1.5 animate-drift" style="left:8%; bottom:10%; animation-delay:0s;"></span>
    <span class="particle h-1 w-1 animate-drift" style="left:18%; bottom:20%; animation-delay:1.4s;"></span>
    <span class="particle h-2 w-2 animate-drift" style="left:32%; bottom:5%; animation-delay:2.8s;"></span>
    <span class="particle h-1 w-1 animate-drift" style="left:60%; bottom:15%; animation-delay:.8s;"></span>
    <span class="particle h-1.5 w-1.5 animate-drift" style="left:74%; bottom:8%; animation-delay:3.6s;"></span>
    <span class="particle h-1 w-1 animate-drift" style="left:90%; bottom:22%; animation-delay:2s;"></span>
  </div>

  <div class="relative mx-auto grid max-w-7xl items-center gap-12 px-5 lg:grid-cols-2 lg:gap-8 lg:px-8">
    <div class="fade-in text-center lg:text-left">
      <p class="section-eyebrow">Online Gaming Platform</p>
      <h1 class="text-balance mt-4 font-heading text-4xl font-bold leading-tight text-white sm:text-5xl lg:text-6xl">
        <span class="gold-text">BDG Win</span><br />
        Play Bold. Win Big.
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-sm leading-relaxed text-grey lg:mx-0 lg:text-base">
        BDG Win brings casino tables, slot reels, lottery draws, sports markets and crash games into a single
        secure account. Register in under a minute, deposit through verified payment methods and track every
        reward from one dashboard built for fast, modern play.
      </p>

      <ul class="mx-auto mt-6 flex max-w-xl flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-grey lg:mx-0 lg:justify-start">
        <li class="flex items-center gap-2"><%- icon('zap', 'w-4 h-4 text-gold') %> Fast Registration</li>
        <li class="flex items-center gap-2"><%- icon('shield-check', 'w-4 h-4 text-gold') %> Secure Platform</li>
        <li class="flex items-center gap-2"><%- icon('sparkles', 'w-4 h-4 text-gold') %> Modern Experience</li>
        <li class="flex items-center gap-2"><%- icon('gift', 'w-4 h-4 text-gold') %> Premium Rewards</li>
      </ul>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-4 lg:justify-start">
        <a href="/register" class="btn-gold animate-pulseGlow">Register on BDG Win</a>
        <a href="/login" class="btn-outline">Login</a>
      </div>
    </div>

    <div class="relative mx-auto flex max-w-md items-center justify-center lg:max-w-none">
      <div class="animate-floaty">
        <img
          src="/images/hero-visual.svg"
          alt="BDG Win gold trophy, casino chips and coins"
          width="640"
          height="720"
          class="h-auto w-full max-w-md drop-shadow-[0_20px_60px_rgba(244,197,66,.25)] lg:max-w-lg"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>

<!-- Game Categories -->
<section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
  <div class="mb-10 text-center">
    <p class="section-eyebrow">Game Categories</p>
    <h2 class="mt-3 text-2xl font-semibold text-white lg:text-3xl">Every BDG Win Game, One Account</h2>
    <p class="mx-auto mt-3 max-w-2xl text-sm text-grey">
      From live casino tables to BDG Win Color Prediction rounds, pick a category and jump straight in.
    </p>
  </div>
  <%- include('../components/game-category-grid', { categories: home.categories, icon }) %>
</section>

<!-- Features -->
<section class="border-y border-goldline bg-card/30">
  <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <div class="mb-10 text-center">
      <p class="section-eyebrow">Why Players Choose BDG Win</p>
      <h2 class="mt-3 text-2xl font-semibold text-white lg:text-3xl">Built for Fast, Secure Play</h2>
    </div>
    <%- include('../components/feature-grid', { features: home.features, icon, gridCols: 4 }) %>
  </div>
</section>

<!-- Why Choose Us -->
<section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
  <div class="mb-10 text-center">
    <p class="section-eyebrow">Why Choose Us</p>
    <h2 class="mt-3 text-2xl font-semibold text-white lg:text-3xl">What Sets BDG Win Apart</h2>
  </div>
  <%- include('../components/feature-grid', { features: home.whyChooseUs, icon, gridCols: 4 }) %>
</section>

<!-- Statistics -->
<%- include('../components/stats', { stats: home.stats }) %>

<!-- Rewards -->
<section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
  <div class="mb-10 text-center">
    <p class="section-eyebrow">BDG Win Rewards</p>
    <h2 class="mt-3 text-2xl font-semibold text-white lg:text-3xl">A Reward for Every Stage of Play</h2>
    <p class="mx-auto mt-3 max-w-2xl text-sm text-grey">
      BDG Win rewards active players with daily streaks, weekly cashback, monthly milestones and a VIP ladder
      that unlocks faster withdrawals.
    </p>
  </div>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    <% home.rewards.forEach(function(r) { %>
    <a href="<%= r.url %>" class="card-surface p-6">
      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-gold/10 text-gold"><%- icon(r.icon, 'w-6 h-6') %></div>
      <h3 class="mb-2 text-base font-semibold text-white"><%= r.title %></h3>
      <p class="text-sm leading-relaxed text-grey"><%= r.description %></p>
    </a>
    <% }); %>
  </div>
</section>

<!-- Referral Program -->
<section class="border-y border-goldline bg-card/30">
  <div class="mx-auto grid max-w-7xl items-center gap-10 px-5 py-16 lg:grid-cols-2 lg:px-8">
    <div>
      <p class="section-eyebrow">Referral Program</p>
      <h2 class="mt-3 text-2xl font-semibold text-white lg:text-3xl">Earn by Inviting Friends to BDG Win</h2>
      <p class="mt-4 text-sm leading-relaxed text-grey">
        Share your BDG Win referral link, and earn a share of your invited friends' activity for as long as
        they play. Track invites, pending earnings and paid-out totals from your account dashboard.
      </p>
      <a href="/referral-program" class="btn-gold mt-6 inline-flex">View Referral Program</a>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div class="card-surface p-6 text-center">
        <p class="gold-text text-3xl font-bold">1</p>
        <p class="mt-2 text-xs text-grey">Share your link</p>
      </div>
      <div class="card-surface p-6 text-center">
        <p class="gold-text text-3xl font-bold">2</p>
        <p class="mt-2 text-xs text-grey">Friend registers</p>
      </div>
      <div class="card-surface p-6 text-center">
        <p class="gold-text text-3xl font-bold">3</p>
        <p class="mt-2 text-xs text-grey">They play games</p>
      </div>
      <div class="card-surface p-6 text-center">
        <p class="gold-text text-3xl font-bold">4</p>
        <p class="mt-2 text-xs text-grey">You earn rewards</p>
      </div>
    </div>
  </div>
</section>

<!-- Download App -->
<section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
  <div class="grid items-center gap-10 lg:grid-cols-2">
    <div class="order-2 grid grid-cols-3 gap-4 lg:order-1">
      <div class="card-surface flex flex-col items-center gap-3 p-6 text-center">
        <%- icon('smartphone', 'w-7 h-7 text-gold') %>
        <p class="text-xs text-grey">Android APK</p>
      </div>
      <div class="card-surface flex flex-col items-center gap-3 p-6 text-center">
        <%- icon('apple', 'w-7 h-7 text-gold') %>
        <p class="text-xs text-grey">iOS Guide</p>
      </div>
      <div class="card-surface flex flex-col items-center gap-3 p-6 text-center">
        <%- icon('monitor', 'w-7 h-7 text-gold') %>
        <p class="text-xs text-grey">Desktop</p>
      </div>
    </div>
    <div class="order-1 lg:order-2">
      <p class="section-eyebrow">Download BDG Win</p>
      <h2 class="mt-3 text-2xl font-semibold text-white lg:text-3xl">Take BDG Win With You</h2>
      <p class="mt-4 text-sm leading-relaxed text-grey">
        Install the BDG Win APK on Android, follow our iOS installation guide, or play instantly from any
        desktop browser without downloading anything.
      </p>
      <a href="/download" class="btn-gold mt-6 inline-flex">Get the BDG Win App</a>
    </div>
  </div>
</section>

<!-- Security -->
<section class="border-y border-goldline bg-card/30">
  <div class="mx-auto grid max-w-7xl items-center gap-10 px-5 py-16 lg:grid-cols-2 lg:px-8">
    <div>
      <p class="section-eyebrow">Security</p>
      <h2 class="mt-3 text-2xl font-semibold text-white lg:text-3xl">Your BDG Win Account, Protected</h2>
      <p class="mt-4 text-sm leading-relaxed text-grey">
        BDG Win protects every account with encrypted sessions, verified payment partners and withdrawal
        checks. Read our full Security and Fair Play pages for details on how outcomes and payouts are
        verified.
      </p>
      <div class="mt-6 flex flex-wrap gap-4">
        <a href="/security" class="btn-outline">Security Details</a>
        <a href="/fair-play" class="btn-outline">Fair Play</a>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div class="card-surface p-6">
        <%- icon('lock', 'w-6 h-6 text-gold') %>
        <p class="mt-3 text-sm font-semibold text-white">Encrypted Sessions</p>
      </div>
      <div class="card-surface p-6">
        <%- icon('badge-check', 'w-6 h-6 text-gold') %>
