<%- include('../components/breadcrumb', { breadcrumb }) %>

<section class="mx-auto flex min-h-[50vh] max-w-2xl flex-col items-center justify-center px-5 py-20 text-center lg:px-8">
  <p class="section-eyebrow"><%= typeof status !== 'undefined' && status !== 404 ? 'Error ' + status : '404' %></p>
  <h1 class="text-balance mt-4 text-3xl font-bold text-white lg:text-4xl">
    <%= typeof message !== 'undefined' ? message : 'This BDG Win page could not be found.' %>
  </h1>
  <p class="mt-4 max-w-md text-sm text-grey">
    The page you were looking for may have moved. Browse our game categories or head back to the BDG Win homepage.
  </p>
  <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
    <a href="/" class="btn-gold">Back to Home</a>
    <a href="/games" class="btn-outline">Browse Games</a>
  </div>
</section>
