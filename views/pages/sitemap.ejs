<%- include('../components/breadcrumb', { breadcrumb }) %>
<%- include('../components/page-hero', { h1: page.h1, intro: page.intro, pageEyebrow: page.eyebrow }) %>

<section class="mx-auto max-w-6xl px-5 py-14 lg:px-8">
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    <% groups.forEach(function(group) { %>
    <div class="card-surface p-6">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-gold"><%= group.label %></h2>
      <ul class="space-y-2 text-sm text-grey">
        <% group.links.forEach(function(link) { %>
        <li><a href="<%= link.url %>" class="hover:text-gold"><%= link.label %></a></li>
        <% }); %>
      </ul>
    </div>
    <% }); %>
  </div>
</section>

<%- include('../components/faq-accordion', { faqs: page.faqs, icon, faqTitle: page.h1 + ' FAQs', faqHeadingId: 'sitemap-faq' }) %>
<%- include('../components/cta', {}) %>
