<%- include('../components/breadcrumb', { breadcrumb }) %>
<%- include('../components/page-hero', { h1: page.h1, intro: page.intro, pageEyebrow: page.eyebrow }) %>

<% if (page.sections && page.sections.length) { %>
<article class="mx-auto max-w-3xl px-5 py-14 lg:px-8">
  <div class="space-y-10">
    <% page.sections.forEach(function(section) { %>
    <div>
      <% if (section.heading) { %><h2 class="mb-3 text-xl font-semibold text-white lg:text-2xl"><%= section.heading %></h2><% } %>
      <% (section.paragraphs || []).forEach(function(p) { %>
      <p class="mb-4 text-sm leading-relaxed text-grey lg:text-base"><%= p %></p>
      <% }); %>
      <% if (section.list && section.list.length) { %>
      <ul class="mb-4 list-inside list-disc space-y-2 text-sm text-grey lg:text-base">
        <% section.list.forEach(function(item) { %><li><%= item %></li><% }); %>
      </ul>
      <% } %>
    </div>
    <% }); %>
  </div>
</article>
<% } %>

<% if (page.related && page.related.length) { %>
<section class="mx-auto max-w-3xl px-5 pb-14 lg:px-8">
  <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-gold">Related BDG Win Pages</h2>
  <div class="flex flex-wrap gap-3">
    <% page.related.forEach(function(link) { %>
    <a href="<%= link.url %>" class="rounded-full border border-goldline px-4 py-2 text-sm text-grey hover:border-gold hover:text-gold"><%= link.label %></a>
    <% }); %>
  </div>
</section>
<% } %>

<% if (page.faqs && page.faqs.length) { %>
<%- include('../components/faq-accordion', { faqs: page.faqs, icon, faqTitle: page.h1 + ' FAQs', faqHeadingId: 'page-faq' }) %>
<% } %>

<%- include('../components/cta', {}) %>
