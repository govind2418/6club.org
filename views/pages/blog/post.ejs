<%- include('../../components/breadcrumb', { breadcrumb }) %>

<article class="mx-auto max-w-3xl px-5 py-14 lg:px-8">
  <header class="mb-8 text-center">
    <% if (category) { %>
    <a href="/blog/category/<%= category.slug %>" class="section-eyebrow">
      <%= category.name %>
    </a>
    <% } %>
    <h1 class="text-balance mt-4 text-2xl font-bold text-white lg:text-4xl"><%= post.title %></h1>
    <div class="mt-4 flex flex-wrap items-center justify-center gap-3 text-xs text-grey">
      <% if (author) { %><a href="/blog/author/<%= author.slug %>" class="hover:text-gold">By <%= author.name %></a><span>&middot;</span><% } %>
      <span><%= post.date %></span>
      <span>&middot;</span>
      <span><%= readingTime %></span>
    </div>
  </header>

  <img src="/images/blog-cover.svg" alt="" width="800" height="450" class="mb-10 w-full rounded-2xl border border-goldline" />

  <% if (toc && toc.length) { %>
  <nav aria-label="Table of contents" class="card-surface mb-10 p-6">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gold">In This Article</h2>
    <ol class="space-y-2 text-sm text-grey">
      <% toc.forEach(function(heading, i) { %>
      <li><a href="#section-<%= i %>" class="hover:text-gold"><%= heading %></a></li>
      <% }); %>
    </ol>
  </nav>
  <% } %>

  <div class="space-y-10">
    <% post.content.forEach(function(section, i) { %>
    <div id="section-<%= i %>">
      <% if (section.heading) { %><h2 class="mb-3 text-xl font-semibold text-white"><%= section.heading %></h2><% } %>
      <% (section.paragraphs || []).forEach(function(p) { %>
      <p class="mb-4 text-sm leading-relaxed text-grey lg:text-base"><%= p %></p>
      <% }); %>
    </div>
    <% }); %>
  </div>

  <% if (author) { %>
  <div class="card-surface mt-12 flex items-start gap-4 p-6">
    <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-gold/10 text-lg font-semibold text-gold">
      <%= author.name.charAt(0) %>
    </div>
    <div>
      <p class="text-sm font-semibold text-white"><a href="/blog/author/<%= author.slug %>" class="hover:text-gold"><%= author.name %></a></p>
      <p class="text-xs text-grey">Author</p>
      <p class="mt-2 text-sm text-grey"><%= author.bio %></p>
    </div>
  </div>
  <% } %>

  <div class="mt-8 flex flex-wrap gap-2">
    <% post.tags.forEach(function(tag) { %>
    <a href="/blog/tag/<%= tag %>" class="rounded-full border border-goldline px-3 py-1 text-xs text-grey hover:border-gold hover:text-gold">#<%= tag %></a>
    <% }); %>
  </div>
</article>

<% if (post.faqs && post.faqs.length) { %>
<%- include('../../components/faq-accordion', { faqs: post.faqs, icon, faqTitle: 'FAQs', faqHeadingId: 'post-faq' }) %>
<% } %>

<% if (relatedPosts && relatedPosts.length) { %>
<section class="mx-auto max-w-6xl px-5 pb-16 lg:px-8">
  <h2 class="mb-6 text-xl font-semibold text-white">Related Articles</h2>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <% relatedPosts.forEach(function(rp) { %>
    <a href="/blog/<%= rp.slug %>" class="card-surface p-5">
      <p class="text-xs uppercase tracking-wide text-gold"><%= rp.date %></p>
      <h3 class="mt-2 text-sm font-semibold text-white"><%= rp.title %></h3>
    </a>
    <% }); %>
  </div>
</section>
<% } %>

<%- include('../../components/cta', {}) %>
