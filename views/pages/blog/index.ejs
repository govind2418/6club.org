<%- include('../../components/breadcrumb', { breadcrumb }) %>

<section class="relative overflow-hidden border-b border-goldline pb-12 pt-32 lg:pt-40">
  <div class="mx-auto max-w-4xl px-5 text-center lg:px-8">
    <p class="section-eyebrow"><%= eyebrow %></p>
    <h1 class="text-balance mt-4 text-3xl font-bold text-white lg:text-5xl"><%= heading %></h1>
  </div>
</section>

<section class="mx-auto max-w-7xl px-5 py-14 lg:px-8">
  <div class="grid gap-10 lg:grid-cols-[2fr_1fr]">
    <div>
      <% if (!posts.length) { %>
      <p class="text-sm text-grey">No articles found in this section yet.</p>
      <% } %>
      <div class="grid gap-6 sm:grid-cols-2">
        <% posts.forEach(function(post) { %>
        <a href="/blog/<%= post.slug %>" class="card-surface flex flex-col overflow-hidden">
          <img src="/images/blog-cover.svg" alt="" width="800" height="450" loading="lazy" class="h-36 w-full object-cover" />
          <div class="flex flex-1 flex-col p-5">
            <p class="text-xs uppercase tracking-wide text-gold"><%= post.date %></p>
            <h2 class="mt-2 text-base font-semibold text-white"><%= post.title %></h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-grey"><%= post.excerpt %></p>
          </div>
        </a>
        <% }); %>
      </div>

      <%- include('../../components/pagination', { pagination, baseUrl }) %>
    </div>

    <%- include('../../components/sidebar', { categories, tags, recentPosts }) %>
  </div>
</section>

<%- include('../../components/newsletter') %>
