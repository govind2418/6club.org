<% if (pagination.totalPages > 1) { %>
<nav aria-label="Pagination" class="mt-12 flex items-center justify-center gap-3">
  <% if (pagination.hasPrev) { %>
  <a href="<%= baseUrl %><%= pagination.prevPage === 1 ? '' : '/page/' + pagination.prevPage %>" class="btn-outline !px-4 !py-2 text-xs">Previous</a>
  <% } %>
  <span class="btn-font text-xs text-grey">Page <%= pagination.currentPage %> of <%= pagination.totalPages %></span>
  <% if (pagination.hasNext) { %>
  <a href="<%= baseUrl %>/page/<%= pagination.nextPage %>" class="btn-outline !px-4 !py-2 text-xs">Next</a>
  <% } %>
</nav>
<% } %>
