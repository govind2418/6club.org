<section class="relative overflow-hidden border-b border-goldline pb-14 pt-32 lg:pt-40">
  <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(circle at 20% -10%, rgba(244,197,66,.14), transparent 55%);"></div>
  <div class="relative mx-auto max-w-4xl px-5 text-center lg:px-8">
    <p class="section-eyebrow"><%= typeof pageEyebrow !== 'undefined' ? pageEyebrow : 'BDG Win' %></p>
    <h1 class="text-balance mt-4 text-3xl font-bold text-white lg:text-5xl"><%= h1 %></h1>
    <p class="mx-auto mt-5 max-w-2xl text-sm leading-relaxed text-grey lg:text-base"><%= intro %></p>
  </div>
</section>
