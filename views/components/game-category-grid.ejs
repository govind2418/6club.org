<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
  <% categories.forEach(function(cat) { %>
  <a href="<%= cat.url %>" class="card-surface group relative overflow-hidden p-6">
    <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-gold/20 to-transparent text-gold">
      <%- icon(cat.icon, 'w-6 h-6') %>
    </div>
    <h3 class="mb-1 text-base font-semibold text-white group-hover:text-gold"><%= cat.title %></h3>
    <p class="text-sm leading-relaxed text-grey"><%= cat.description %></p>
    <span class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-gold btn-font">
      Explore <%- icon('arrow-right', 'w-3.5 h-3.5') %>
    </span>
  </a>
  <% }); %>
</div>
