<section class="mx-auto max-w-4xl px-5 py-16 lg:px-8" aria-labelledby="<%= typeof faqHeadingId !== 'undefined' ? faqHeadingId : 'faq-heading' %>">
  <div class="mb-10 text-center">
    <p class="section-eyebrow">FAQs</p>
    <h2 id="<%= typeof faqHeadingId !== 'undefined' ? faqHeadingId : 'faq-heading' %>" class="mt-3 text-2xl font-semibold text-white lg:text-3xl">
      <%= typeof faqTitle !== 'undefined' ? faqTitle : 'Frequently Asked Questions' %>
    </h2>
  </div>

  <div class="space-y-3">
    <% faqs.forEach(function(faq, index) { %>
    <div data-faq-item data-open="false" class="card-surface overflow-hidden">
      <button
        type="button"
        data-faq-question
        class="flex w-full items-center justify-between gap-4 px-5 py-4 text-left"
        aria-expanded="false"
        aria-controls="faq-answer-<%= index %>"
      >
        <span class="text-sm font-semibold text-white lg:text-base"><%= faq.q %></span>
        <%- icon('plus', 'w-4 h-4 shrink-0 text-gold') %>
      </button>
      <div id="faq-answer-<%= index %>" data-faq-answer class="max-h-0 overflow-hidden px-5 text-sm leading-relaxed text-grey transition-[max-height] duration-300">
        <p class="pb-5"><%= faq.a %></p>
      </div>
    </div>
    <% }); %>
  </div>
</section>
