<section class="relative mx-auto my-10 max-w-6xl overflow-hidden rounded-3xl border border-goldline px-6 py-14 text-center lg:px-16" style="background: radial-gradient(circle at 50% 0%, rgba(244,197,66,.12), transparent 60%), #0c0c0c;">
  <div class="pointer-events-none absolute -left-10 -top-10 h-40 w-40 rounded-full bg-gold/10 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-10 -right-10 h-40 w-40 rounded-full bg-gold/10 blur-3xl"></div>

  <p class="section-eyebrow"><%= typeof ctaEyebrow !== 'undefined' ? ctaEyebrow : 'Join BDG Win' %></p>
  <h2 class="mx-auto mt-3 max-w-2xl text-2xl font-semibold text-white lg:text-3xl">
    <%= typeof ctaTitle !== 'undefined' ? ctaTitle : 'Create your BDG Win account and start playing today' %>
  </h2>
  <p class="mx-auto mt-3 max-w-xl text-sm text-grey">
    <%= typeof ctaDescription !== 'undefined' ? ctaDescription : 'Registration takes under a minute. Verify your number, claim your welcome bonus and pick a game category to begin.' %>
  </p>
  <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
    <a href="<%= typeof ctaPrimaryUrl !== 'undefined' ? ctaPrimaryUrl : '/register' %>" class="btn-gold">
      <%= typeof ctaPrimaryLabel !== 'undefined' ? ctaPrimaryLabel : 'Register on BDG Win' %>
    </a>
    <a href="<%= typeof ctaSecondaryUrl !== 'undefined' ? ctaSecondaryUrl : '/login' %>" class="btn-outline">
      <%= typeof ctaSecondaryLabel !== 'undefined' ? ctaSecondaryLabel : 'Login to Your Account' %>
    </a>
  </div>
</section>
