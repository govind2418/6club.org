<section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
  <div class="mb-10 text-center">
    <p class="section-eyebrow">Player Voices</p>
    <h2 class="mt-3 text-2xl font-semibold text-white lg:text-3xl">What BDG Win Players Are Saying</h2>
  </div>
  <div class="grid gap-6 lg:grid-cols-3">
    <% testimonials.forEach(function(t) { %>
    <figure class="card-surface p-6">
      <div class="mb-4 flex gap-1 text-gold">
        <% for (var i = 0; i < 5; i++) { %><%- icon('star', 'w-4 h-4 fill-current') %><% } %>
      </div>
      <blockquote class="text-sm leading-relaxed text-grey">&ldquo;<%= t.quote %>&rdquo;</blockquote>
      <figcaption class="mt-5 flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gold/10 text-sm font-semibold text-gold">
          <%= t.name.charAt(0) %>
        </div>
        <div>
          <p class="text-sm font-semibold text-white"><%= t.name %></p>
          <p class="text-xs text-grey"><%= t.role %></p>
        </div>
      </figcaption>
    </figure>
    <% }); %>
  </div>
</section>
