<header data-site-header class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-colors duration-300">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 lg:px-8">
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="BDG Win home">
      <img src="/images/logo.svg" alt="BDG Win" width="150" height="36" class="h-8 w-auto lg:h-9" />
    </a>

    <nav aria-label="Primary" class="hidden lg:block">
      <ul class="flex items-center gap-1">
        <% nav.primary.forEach(function(item) { %>
        <li class="group relative">
          <a href="<%= item.url %>" class="btn-font flex items-center gap-1 rounded-full px-4 py-2 text-sm font-medium text-grey transition-colors hover:text-gold">
            <%= item.label %>
            <% if (item.children) { %><%- icon('chevron-down', 'w-3.5 h-3.5') %><% } %>
          </a>
          <% if (item.children) { %>
          <div class="invisible absolute left-1/2 top-full z-20 w-64 -translate-x-1/2 translate-y-1 rounded-xl border border-goldline bg-card p-2 opacity-0 shadow-glow transition-all duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
            <% item.children.forEach(function(child) { %>
            <a href="<%= child.url %>" class="block rounded-lg px-3 py-2 text-sm text-grey hover:bg-white/5 hover:text-gold"><%= child.label %></a>
            <% }); %>
          </div>
          <% } %>
        </li>
        <% }); %>
      </ul>
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a href="/login" class="btn-outline !px-5 !py-2 text-xs">Login</a>
      <a href="/register" class="btn-gold !px-5 !py-2 text-xs">Register</a>
    </div>

    <button
      type="button"
      data-menu-toggle
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Toggle navigation menu"
      class="flex h-10 w-10 items-center justify-center rounded-full border border-goldline text-gold lg:hidden"
    >
      <%- icon('menu', 'w-5 h-5') %>
    </button>
  </div>

  <nav
    id="mobile-menu"
    data-mobile-menu
    aria-label="Mobile"
    class="hidden flex-col gap-1 border-t border-goldline bg-black/95 px-5 py-4 lg:hidden"
  >
    <% nav.primary.forEach(function(item) { %>
    <a href="<%= item.url %>" class="block rounded-lg px-3 py-2 text-sm font-medium text-grey hover:bg-white/5 hover:text-gold"><%= item.label %></a>
    <% }); %>
    <div class="mt-3 flex gap-3 border-t border-goldline pt-3">
      <a href="/login" class="btn-outline flex-1 !py-2 text-xs">Login</a>
      <a href="/register" class="btn-gold flex-1 !py-2 text-xs">Register</a>
    </div>
  </nav>
</header>
